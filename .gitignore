# tools/video — keep the rendered MP4 but ignore intermediate WAVs.
# The 14 per-segment WAVs can be regenerated by running
# `python tools/generate_narration.py` (needs Edge TTS + a network
# connection to Microsoft). The concatenated narration_full.wav is
# also re-derived by concat-ing the 14 segments; the deterministic
# final mix lives in pharos-intro-final.mp4.
tools/video/assets/audio/*.wav
tools/video/assets/narration_full.wav
tools/video/pharos-intro.mp4
tools/video/renders/
