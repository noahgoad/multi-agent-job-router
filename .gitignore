# tools/video — keep the rendered MP4s but ignore intermediate WAVs.
# The 14 per-segment WAVs can be regenerated by running
# `python tools/generate_narration.py` (Vietnamese) or
# `python tools/generate_narration_en.py` (English). Each script needs
# Edge TTS + a network connection to Microsoft. The concatenated
# `narration_full.wav` / `narration_en_full.wav` are also re-derived
# by concat-ing the 14/20 segments; the deterministic final mix
# lives in pharos-intro-{,en-}final.mp4.
tools/video/assets/audio/*.wav
tools/video/assets/audio-en/*.wav
tools/video/assets/narration_full.wav
tools/video/assets/narration_en_full.wav
tools/video/pharos-intro.mp4
tools/video/pharos-intro-en.mp4
tools/video/renders/
